{
  "name": "opencode-phone-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:css && npm run build:astro",
    "build:client": "vite build -c vite.client.config.js",
    "build:css": "tailwindcss -i src/styles/input.css -o public/styles.css --minify",
    "build:astro": "astro build",
    "dev": "astro dev",
    "preview": "npm run build && wrangler dev -c dist/server/wrangler.json",
    "deploy": "npm run build && wrangler deploy -c dist/server/wrangler.json",
    "db:migrate:local": "wrangler d1 migrations apply opencode_phone --local",
    "db:migrate": "wrangler d1 migrations apply opencode_phone --remote",
    "typecheck": "astro check"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@tailwindcss/cli": "^4.3.1",
    "typescript": "latest",
    "vite": "^7.0.0",
    "wrangler": "^4.100.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@astrojs/cloudflare": "^13.7.0",
    "ai": "^6.0.206",
    "astro": "^6.4.7",
    "hono": "^4.12.25",
    "remix": "^3.0.0-beta.4",
    "zod": "^4.4.3"
  }
}
