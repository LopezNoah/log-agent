---
// Document skeleton only. The entire UI is a Remix component (src/client/app.tsx) mounted into
// #root by the client bundle — there is no static layout markup here.
//
// SSR pre-fetch: read the cached session list straight from the SyncHub durable object (the same
// data it sends over the /sync WebSocket on connect) and inline it so the session rail paints on
// first render instead of waiting for the WebSocket round-trip. Pure cache read — no upstream call,
// never wakes the Fly box. Falls back silently to the WebSocket snapshot if the DO is unreachable.
import { env } from "cloudflare:workers";

let bootSessions: unknown[] = [];
try {
  bootSessions = await env.SYNC.getByName("hub").snapshotSessions();
} catch {
  /* DO unavailable — the client still loads sessions over the WebSocket */
}
let bootJson = JSON.stringify({ sessions: bootSessions }).replace(/</g, "\\u003c");
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>opencode phone</title>
  <link rel="stylesheet" href="/vendor/katex/katex.min.css">
  <link rel="stylesheet" href="/styles.css">
  <script id="oc-boot" type="application/json" set:html={bootJson}></script>
  <script is:inline defer src="/vendor/marked.min.js"></script>
  <script is:inline defer src="/vendor/katex/katex.min.js"></script>
  <script is:inline defer src="/vendor/marked-katex.umd.js"></script>
  <script is:inline defer src="/vendor/purify.min.js"></script>
</head>
<body class="bg-ink text-zinc-100 antialiased">
  <div id="root"></div>
  <script is:inline src="/assets/app.js" type="module"></script>
</body>
</html>
